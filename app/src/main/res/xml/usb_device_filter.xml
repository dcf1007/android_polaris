<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Some Android devices do not expose the USB Video interface class before the
        app has requested USB permission, even when the device is a UVC camera.
        Use a broad attach filter so the app can launch, inspect the raw USB list,
        request permission, and then let libuvc validate the camera.
    -->
    <usb-device />
</resources>
